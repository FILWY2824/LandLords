# LandLords 正式配置文件
#
# 这份文件会被仓库直接跟踪。开源部署时，不需要复制模板，也不需要自己补配置键；
# 用户要做的事情只有一件：按自己机器和服务器环境，修改下面已经写好的默认示例值。
#
# 推荐使用顺序：
# 1. 先看“一、后端构建与原生依赖定位”，改好 protobuf / libevent / onnxruntime / Python 路径
# 2. 再看“二、前端编译期配置”和“三、后端运行期配置”，改好前后端地址与端口
# 3. 运行：
#    powershell -NoProfile -ExecutionPolicy Bypass -File .\run_backend_windows.ps1
# 4. 后端运行后，再执行：
#    powershell -NoProfile -ExecutionPolicy Bypass -File .\run_frontend_windows.ps1
#
# 第一次部署最需要优先修改的内容：
# - LANDLORDS_WINDOWS_DEPS_ROOT
# - LANDLORDS_ONNXRUNTIME_ROOT
# - 如果你不走 bundle 模式，还要改 LANDLORDS_PROTOBUF_* 和 LANDLORDS_LIBEVENT_*
# - LANDLORDS_HOST / LANDLORDS_PORT / LANDLORDS_WS_PORT
# - LANDLORDS_WEB_HOST / LANDLORDS_WEB_PORT / LANDLORDS_BACKEND_WS_PROXY
#
# 路径填写规则：
# - 仓库内部资源建议优先写“相对于仓库根目录的相对路径”
# - 系统里单独安装的 SDK / 依赖建议写“绝对路径”
# - Windows 路径建议统一写成正斜杠，例如：D:/sdk/protobuf
#
# 下面所有变量都已经写入默认值。别人部署时，不需要再自己补配置键，只需要按注释修改。

# -----------------------------------------------------------------------------
# 一、后端构建与原生依赖定位
# -----------------------------------------------------------------------------
# 这一段会被 run_backend_windows.ps1 读取，用来决定：
# - CMake 使用什么生成器
# - 后端构建目录放在哪里
# - protobuf / libevent / onnxruntime 从哪里查找
#
# Windows 常见配置：
#   LANDLORDS_CMAKE_GENERATOR=Visual Studio 17 2022
#   LANDLORDS_CMAKE_PLATFORM=x64
#   LANDLORDS_CMAKE_BUILD_DIR=backend/server/build-vs
#   LANDLORDS_CMAKE_BUILD_CONFIG=Debug
#
# Linux 常见配置：
#   LANDLORDS_CMAKE_GENERATOR=Ninja
#   LANDLORDS_CMAKE_BUILD_TYPE=Release
#   LANDLORDS_CMAKE_BUILD_DIR=backend/server/build
LANDLORDS_CMAKE_GENERATOR=Visual Studio 17 2022
LANDLORDS_CMAKE_PLATFORM=x64
LANDLORDS_CMAKE_BUILD_DIR=backend/server/build-vs
LANDLORDS_CMAKE_BUILD_CONFIG=Debug
LANDLORDS_CMAKE_BUILD_TYPE=
LANDLORDS_BACKEND_TARGETS=landlords_server
LANDLORDS_SERVER_EXE=

# 推荐的 Windows bundle 模式：
#   <deps_root>/protobuf
#   <deps_root>/libevent
#
# 这种模式对开源部署最省事：
# - 保持 LANDLORDS_USE_LOCAL_WINDOWS_DEPS=ON
# - 只改 LANDLORDS_WINDOWS_DEPS_ROOT 一项即可
# - 第一次部署前必须改成你自己机器上的真实目录
LANDLORDS_USE_LOCAL_WINDOWS_DEPS=ON
LANDLORDS_WINDOWS_DEPS_ROOT=D:/sdk/landlords/windows_deps

# 下面这些是“分开指定依赖”的覆盖项。
# 只有在你不想使用统一 deps_root，或者你的 protobuf / libevent 不在同一目录时，才需要填写。
# 如果仍然使用 bundle 模式，这些值可以保留示例，不参与实际构建。
LANDLORDS_PROTOBUF_ROOT=D:/sdk/protobuf
LANDLORDS_PROTOBUF_PROTOC_EXECUTABLE=D:/sdk/protobuf/bin/protoc.exe
LANDLORDS_PROTOBUF_INCLUDE_DIR=D:/sdk/protobuf/include
LANDLORDS_PROTOBUF_LIBRARY=D:/sdk/protobuf/lib/libprotobuf.lib
LANDLORDS_LIBEVENT_ROOT=D:/sdk/libevent
LANDLORDS_LIBEVENT_CMAKE_DIR=D:/sdk/libevent/lib/cmake/libevent
LANDLORDS_CMAKE_PREFIX_PATH=

# 这是 C++ 后端直接加载 ONNX Runtime 时使用的 SDK 根目录。
# 这项默认值也是示例值，第一次部署前必须改成你本机的真实目录。
LANDLORDS_ENABLE_ONNXRUNTIME=ON
LANDLORDS_ONNXRUNTIME_ROOT=D:/sdk/onnxruntime/Microsoft.ML.OnnxRuntime.1.24.3


# -----------------------------------------------------------------------------
# 二、前端编译期配置
# -----------------------------------------------------------------------------
# 这一段会通过 --dart-define 注入 Flutter Web。
# 如果你改了这里的地址，重新执行前端构建后才会生效。
#
# LANDLORDS_WS_URL：
# - 留空：前端默认走相对路径 /ws，适合同域部署，并由 run_frontend_windows.ps1 代理到后端
# - 填完整 ws:// 或 wss:// 地址：前端会直接连接你指定的 WebSocket 服务
LANDLORDS_WS_URL=

# 登录页和发布页会用到这些地址。
# 开源发布时，建议把 LANDLORDS_GITHUB_REPO 改成你公开仓库的实际链接。
LANDLORDS_GITHUB_REPO=https://github.com/FILWY2824/LandLords
LANDLORDS_DOWNLOAD_URL=


# -----------------------------------------------------------------------------
# 三、后端运行期配置
# -----------------------------------------------------------------------------
# 这一段由后端可执行文件和运行脚本读取，决定服务监听方式和运行数据落盘位置。
#
# LANDLORDS_HOST：
# - 127.0.0.1：只允许本机访问，适合单机开发
# - 0.0.0.0：监听所有网卡，适合局域网联机、反向代理或公网部署
LANDLORDS_HOST=0.0.0.0
LANDLORDS_PORT=23001
LANDLORDS_WS_PORT=23002

# 用户数据、好友数据和运行时文件会写到这里。
# 开源部署到服务器时，建议改到独立的数据目录、挂载卷或持久化目录。
LANDLORDS_DATA_DIR=runtime

# 可选值通常为 DEBUG / INFO / WARN / ERROR。
# 对外部署建议先用 INFO；排查问题时再临时改成 DEBUG。
LANDLORDS_LOG_LEVEL=INFO

# 房间逻辑 Tick 间隔，单位毫秒。
# 除非你明确在做性能实验，否则一般不建议修改。
LANDLORDS_ROOM_TICK_INTERVAL_MS=100


# -----------------------------------------------------------------------------
# 四、DouZero ONNX 模型配置
# -----------------------------------------------------------------------------
# 这一段控制不同难度使用哪套 ONNX 模型目录。
# 如果同时填写了总目录和分难度目录，分难度目录优先。
LANDLORDS_DOUZERO_ONNX_DIR=
LANDLORDS_DOUZERO_ONNX_DIR_EASY=backend/ai_models/onnx/douzero_ADP
LANDLORDS_DOUZERO_ONNX_DIR_NORMAL=backend/ai_models/onnx/sl
LANDLORDS_DOUZERO_ONNX_DIR_HARD=backend/ai_models/onnx/douzero_WP

# ONNX 推理线程数。
# 低配机器可以先保持 1；服务器 CPU 资源充足时，再按压测结果逐步调大。
LANDLORDS_ONNX_NUM_THREADS=1

# 提示按钮和托管机器人默认使用的难度。
# 常见值：easy / normal / hard
LANDLORDS_HINT_BOT_DIFFICULTY=hard
LANDLORDS_MANAGED_BOT_DIFFICULTY=hard


# -----------------------------------------------------------------------------
# 五、房间节奏与表现层延时
# -----------------------------------------------------------------------------
# 这一段主要影响：
# - 托管 / 机器人思考等待时间
# - 出牌提示展示停留时间
# - 结算前后的停顿
# 默认值更偏向“像真人在操作”的节奏。
# 如果你只是做自动化测试、压测或快速联调，可以适当调小这些时间。
LANDLORDS_BOT_MODEL_RETRY_DELAY_MS=1500
LANDLORDS_MANAGED_NOTICE_DELAY_MS=2300
LANDLORDS_BID_PASS_NOTICE_DELAY_MS=1700
LANDLORDS_BID_NOTICE_DELAY_MS=2200
LANDLORDS_PASS_NOTICE_DELAY_MS=1800
LANDLORDS_SIMPLE_PLAY_NOTICE_DELAY_MS=2200
LANDLORDS_COMPLEX_PLAY_NOTICE_DELAY_MS=3000
LANDLORDS_BOMB_NOTICE_DELAY_MS=3400
LANDLORDS_ROCKET_NOTICE_DELAY_MS=3800
LANDLORDS_DEFAULT_NOTICE_DELAY_MS=2200
LANDLORDS_MANAGED_DELAY_MIN_MS=380
LANDLORDS_MANAGED_DELAY_MAX_MS=680
LANDLORDS_BOT_BID_DELAY_MIN_MS=260
LANDLORDS_BOT_BID_DELAY_MAX_MS=460
LANDLORDS_BOT_PLAY_DELAY_MIN_MS=320
LANDLORDS_BOT_PLAY_DELAY_MAX_MS=520
LANDLORDS_PRESENTATION_TIMEOUT_MS=15000
LANDLORDS_FINISH_DELAY_MS=520


# -----------------------------------------------------------------------------
# 六、Web 发布服务
# -----------------------------------------------------------------------------
# run_frontend_windows.ps1 会：
# 1. 构建 Flutter Web
# 2. 启动本地静态文件服务
# 3. 把浏览器访问的 /ws 代理到后端 WebSocket
LANDLORDS_WEB_HOST=0.0.0.0
LANDLORDS_WEB_PORT=23000
LANDLORDS_BACKEND_WS_PROXY=ws://127.0.0.1:23002/ws


# -----------------------------------------------------------------------------
# 七、集成测试与 smoke 脚本
# -----------------------------------------------------------------------------
# 这一段会被 test/ 和 tool/ 下的联机验证脚本读取。
# 如果你改了后端监听地址或端口，这里也要同步修改，否则测试会连到旧地址。
LANDLORDS_TEST_HOST=127.0.0.1
LANDLORDS_TEST_TCP_PORT=23001
LANDLORDS_TEST_WS_PORT=23002


# -----------------------------------------------------------------------------
# 八、Python DouZero ONNX 导出与校验工具
# -----------------------------------------------------------------------------
# 如果你要重新导出 ONNX，或者用 Python 环境校验 checkpoint 与 ONNX 是否一致，就重点看这一段。
# LANDLORDS_PYTHON 可以写命令名，也可以写完整路径，例如：
#   LANDLORDS_PYTHON=python
#   LANDLORDS_PYTHON=C:/Python39/python.exe
LANDLORDS_PYTHON=python

# 下面是 DouZero 代码、baseline、设备和导出控制项。
# 仓库已经保留了导出所需的最小 DouZero 子集；如需改成本机其他路径，直接在这里改即可。
LANDLORDS_DOUZERO_ROOT=third_party/DouZero
LANDLORDS_DOUZERO_BASELINE_DIR=third_party/baselines/douzero_ADP
LANDLORDS_DOUZERO_DEVICE=cpu
LANDLORDS_DOUZERO_NUM_THREADS=4
LANDLORDS_DOUZERO_PRELOAD=1
LANDLORDS_DOUZERO_WARMUP=1
LANDLORDS_DOUZERO_EXPORT_OUTPUT_DIR=
LANDLORDS_DOUZERO_EXPORT_DEVICE=cpu
LANDLORDS_DOUZERO_LOG_LEVEL=INFO
