# LandLords 正式配置文件
#
# 这份文件会被仓库直接跟踪。开源部署时，不需要复制模板，也不需要自己补参数；
# 用户要做的事情只有一件：把下面这些示例值改成自己机器上的真实值。
#
# 重要说明：
# - 下面出现的 `D:/sdk/...` 都只是示例路径，不是仓库自带可直接使用的真实目录。
# - 当前开源部署方案统一使用“逐项指定依赖路径”的方式，不再使用 bundle 模式。
# - 如果你已经在当前终端里预先导入了同名环境变量，脚本会优先使用终端中的值；未导入时才回落到这里的默认值。
# - 如果某个参数留空，注释里会明确写出“留空代表什么”；没有写的都不建议留空。
# - 仓库内部资源建议优先写“相对仓库根目录的路径”，系统里单独安装的软件建议写“绝对路径”。
# - Windows 路径建议统一写成正斜杠，例如 `D:/sdk/protobuf`，这样在 PowerShell、CMake 和文档里都更稳定。
#
# 推荐修改顺序：
# 1. 先改“后端构建与依赖”部分，确保 protobuf、libevent、onnxruntime、Python 路径正确
# 2. 再改“后端运行”和“Web 发布”部分，确保监听地址、端口、代理地址正确
# 3. 最后按顺序执行：
#    powershell -NoProfile -ExecutionPolicy Bypass -File .\run_backend_windows.ps1
#    powershell -NoProfile -ExecutionPolicy Bypass -File .\run_frontend_windows.ps1

# -----------------------------------------------------------------------------
# 一、后端构建与依赖
# -----------------------------------------------------------------------------

# LANDLORDS_CMAKE_GENERATOR:
# Windows 下使用的 CMake 生成器名称。
# 一般保持 `Visual Studio 17 2022` 即可，除非你明确切换了本机生成器。
LANDLORDS_CMAKE_GENERATOR=Visual Studio 17 2022

# LANDLORDS_CMAKE_PLATFORM:
# 目标架构。当前 Windows 后端统一按 x64 构建。
LANDLORDS_CMAKE_PLATFORM=x64

# LANDLORDS_CMAKE_BUILD_DIR:
# 后端构建输出目录，路径相对仓库根目录。
# 这里会生成 Visual Studio 工程、中间文件和最终可执行文件。
# 第一次部署如果你没有特殊目录规划，直接保留默认值即可。
LANDLORDS_CMAKE_BUILD_DIR=backend/server/build-vs

# LANDLORDS_CMAKE_BUILD_CONFIG:
# 多配置生成器使用的构建配置。
# Visual Studio 常见值：Debug / Release。
# 第一次部署建议先用 Debug 跑通；准备正式发布时再改成 Release。
LANDLORDS_CMAKE_BUILD_CONFIG=Debug

# LANDLORDS_CMAKE_BUILD_TYPE:
# 单配置生成器使用的构建类型，例如 Ninja、Unix Makefiles。
# Windows 下用 Visual Studio 时通常留空即可；Linux 上常填 Release。
LANDLORDS_CMAKE_BUILD_TYPE=

# LANDLORDS_SERVER_EXE:
# 可选项。手动指定后端可执行文件路径。
# 只有当你把 `landlords_server.exe` 放到了默认构建目录以外的位置时才需要填写。
# 第一次部署建议留空，脚本会自动从构建目录寻找可执行文件。
LANDLORDS_SERVER_EXE=

# LANDLORDS_PROTOBUF_ROOT:
# protobuf 安装根目录。
# 作用：
# 1. 让后端构建阶段能定位 protobuf 的整体安装位置
# 2. 让构建后的 DLL 拷贝逻辑能够找到 protobuf 运行时文件
# 示例目录结构通常包含：bin / include / lib
# 第一次部署必须改成你自己机器上的真实 protobuf 安装目录。
LANDLORDS_PROTOBUF_ROOT=D:/sdk/protobuf

# LANDLORDS_PROTOBUF_PROTOC_EXECUTABLE:
# protoc 编译器的完整路径。
# 这个工具会在构建时用于处理 protobuf 代码生成相关流程。
# 第一次部署必须改成你本机实际的 `protoc.exe` 路径。
LANDLORDS_PROTOBUF_PROTOC_EXECUTABLE=D:/sdk/protobuf/bin/protoc.exe

# LANDLORDS_PROTOBUF_INCLUDE_DIR:
# protobuf 头文件目录。
# 这个目录下应能找到 `google/protobuf/stubs/common.h`。
# 如果你不确定有没有填对，优先检查这个头文件是否真实存在。
LANDLORDS_PROTOBUF_INCLUDE_DIR=D:/sdk/protobuf/include

# LANDLORDS_PROTOBUF_LIBRARY:
# protobuf 链接库文件的完整路径。
# Windows 下通常是 `libprotobuf.lib` 或 `libprotobufd.lib`。
# 如果你当前按 Debug 构建，常见做法是填 `libprotobufd.lib`；Release 则常用 `libprotobuf.lib`。
LANDLORDS_PROTOBUF_LIBRARY=D:/sdk/protobuf/lib/libprotobuf.lib

# LANDLORDS_LIBEVENT_ROOT:
# libevent 安装根目录。
# 作用：
# 1. 让构建后的 DLL 拷贝逻辑找到 `event_core.dll`、`event_extra.dll`
# 2. 作为 libevent 相关文件的统一根路径
# 第一次部署必须改成你自己机器上的真实 libevent 安装目录。
LANDLORDS_LIBEVENT_ROOT=D:/sdk/libevent

# LANDLORDS_LIBEVENT_CMAKE_DIR:
# 包含 `LibeventConfig.cmake` 的目录。
# CMake 会通过这个目录找到 libevent 的官方配置包。
# 这个目录通常形如 `.../lib/cmake/libevent`，不要直接填 libevent 根目录。
LANDLORDS_LIBEVENT_CMAKE_DIR=D:/sdk/libevent/lib/cmake/libevent

# LANDLORDS_CMAKE_PREFIX_PATH:
# 可选项。额外的 CMake 依赖搜索路径。
# 当你的依赖安装在非标准目录、或者还需要额外前缀路径时再填写。
# 不需要时留空；第一次部署大多数用户都可以保持留空。
LANDLORDS_CMAKE_PREFIX_PATH=

# LANDLORDS_ENABLE_ONNXRUNTIME:
# 是否启用 ONNX Runtime。
# 当前项目默认使用 ONNX 进行机器人决策，所以通常保持 ON。
# 可选值：ON / OFF
LANDLORDS_ENABLE_ONNXRUNTIME=ON

# LANDLORDS_ONNXRUNTIME_ROOT:
# ONNX Runtime SDK 根目录。
# 这个目录下需要能找到：
# - build/native/include/onnxruntime_cxx_api.h
# - runtimes/win-x64/native/onnxruntime.lib
# - runtimes/win-x64/native/onnxruntime.dll
# 第一次部署必须改成你自己机器上的真实 ONNX Runtime SDK 解压目录。
LANDLORDS_ONNXRUNTIME_ROOT=D:/sdk/onnxruntime/Microsoft.ML.OnnxRuntime.1.24.3


# -----------------------------------------------------------------------------
# 二、前端编译期配置
# -----------------------------------------------------------------------------

# LANDLORDS_WS_URL:
# Flutter Web 编译时注入的 WebSocket 地址。
# 留空表示前端使用相对路径 `/ws`，由本项目自带的 Web 静态服务代理到后端。
# 如果你已经有现成的反向代理或公网 WebSocket 地址，也可以直接填写完整的 ws:// 或 wss:// 地址。
# 如果你就是按本仓库推荐方式运行 `run_frontend_windows.ps1`，通常保持留空最省事。
LANDLORDS_WS_URL=

# LANDLORDS_GITHUB_REPO:
# 前端登录页、项目入口页中展示的仓库地址。
# 这不会影响编译和运行，但开源发布时建议改成你自己仓库的真实链接。
LANDLORDS_GITHUB_REPO=https://github.com/FILWY2824/LandLords

# LANDLORDS_DOWNLOAD_URL:
# 前端页面里展示的下载地址或发布页地址。
# 如果你暂时没有独立下载页，可以留空；留空只是不显示下载入口，不影响部署。
LANDLORDS_DOWNLOAD_URL=


# -----------------------------------------------------------------------------
# 三、后端运行期配置
# -----------------------------------------------------------------------------

# LANDLORDS_HOST:
# 后端服务监听 IP。
# - 127.0.0.1：只允许本机访问，适合单机开发
# - 0.0.0.0：允许局域网、公网或反向代理访问，适合正式部署
# 如果你第一次只是本机验证，也可以先改成 127.0.0.1，确认跑通后再放开到 0.0.0.0。
LANDLORDS_HOST=0.0.0.0

# LANDLORDS_PORT:
# 后端 TCP 端口。
# TCP 客户端或测试脚本会连接这个端口。
# 如果这台机器上 23001 已被占用，就换一个没冲突的端口，并同步修改测试端口。
LANDLORDS_PORT=23001

# LANDLORDS_WS_PORT:
# 后端 WebSocket 端口。
# Web 前端和 WebSocket 测试脚本会连接这个端口。
# 如果改了这个值，记得同步修改 `LANDLORDS_BACKEND_WS_PROXY` 和 `LANDLORDS_TEST_WS_PORT`。
LANDLORDS_WS_PORT=23002

# LANDLORDS_DATA_DIR:
# 后端运行期数据目录。
# 用户数据、房间数据、运行期落盘文件都会写到这里。
# 建议正式部署时改到独立数据盘、持久化卷或专门的 runtime 目录。
# 使用官方脚本时，相对路径默认相对仓库根目录解析。
LANDLORDS_DATA_DIR=runtime

# LANDLORDS_LOG_LEVEL:
# 后端日志级别。
# 常用值：DEBUG / INFO / WARN / ERROR。
# 正式部署推荐 INFO，排查复杂问题时再临时改成 DEBUG。
LANDLORDS_LOG_LEVEL=INFO

# LANDLORDS_ROOM_TICK_INTERVAL_MS:
# 房间逻辑 Tick 间隔，单位毫秒。
# 间隔越小，房间状态推进越频繁；除非你明确做性能调优，否则不要修改。
LANDLORDS_ROOM_TICK_INTERVAL_MS=100


# -----------------------------------------------------------------------------
# 四、机器人 ONNX 模型配置
# -----------------------------------------------------------------------------

# LANDLORDS_DOUZERO_ONNX_DIR:
# 可选总开关。给三档难度统一指定一个 ONNX 模型目录。
# 如果填写了这个值，而分难度目录又留空，那么三档难度都会优先回落到这里。
# 正常情况下建议留空，直接使用下面三个分难度目录。
LANDLORDS_DOUZERO_ONNX_DIR=

# LANDLORDS_DOUZERO_ONNX_DIR_EASY:
# 简单难度机器人使用的 ONNX 模型目录。
# 目录内应包含 landlord.onnx / landlord_up.onnx / landlord_down.onnx / manifest.json。
# 如果你直接使用仓库已提供的模型，保持默认值即可；只有替换模型时才需要改。
LANDLORDS_DOUZERO_ONNX_DIR_EASY=backend/ai_models/onnx/douzero_ADP

# LANDLORDS_DOUZERO_ONNX_DIR_NORMAL:
# 普通难度机器人使用的 ONNX 模型目录。
# 如果你直接使用仓库已提供的模型，保持默认值即可。
LANDLORDS_DOUZERO_ONNX_DIR_NORMAL=backend/ai_models/onnx/sl

# LANDLORDS_DOUZERO_ONNX_DIR_HARD:
# 困难难度机器人使用的 ONNX 模型目录。
# 如果你直接使用仓库已提供的模型，保持默认值即可。
LANDLORDS_DOUZERO_ONNX_DIR_HARD=backend/ai_models/onnx/douzero_WP

# LANDLORDS_ONNX_NUM_THREADS:
# ONNX 推理线程数。
# CPU 核心少的机器建议先保持 1；服务器资源充足时可以逐步调大后压测。
LANDLORDS_ONNX_NUM_THREADS=1

# LANDLORDS_HINT_BOT_DIFFICULTY:
# “提示出牌”功能默认使用的机器人难度。
# 可选值：easy / normal / hard。
LANDLORDS_HINT_BOT_DIFFICULTY=hard

# LANDLORDS_MANAGED_BOT_DIFFICULTY:
# “托管出牌”功能默认使用的机器人难度。
# 可选值：easy / normal / hard。
LANDLORDS_MANAGED_BOT_DIFFICULTY=hard


# -----------------------------------------------------------------------------
# 五、房间节奏与表现层延时
# -----------------------------------------------------------------------------

# LANDLORDS_BOT_MODEL_RETRY_DELAY_MS:
# 当模型暂时不可用或上一轮动作需要等待时，机器人重试模型决策前的等待时间。
LANDLORDS_BOT_MODEL_RETRY_DELAY_MS=1500

# LANDLORDS_MANAGED_NOTICE_DELAY_MS:
# 玩家切换为托管后，托管提示在界面上的保留时间。
LANDLORDS_MANAGED_NOTICE_DELAY_MS=2300

# LANDLORDS_BID_PASS_NOTICE_DELAY_MS:
# 叫分阶段选择“不叫”后的提示展示时间。
LANDLORDS_BID_PASS_NOTICE_DELAY_MS=1700

# LANDLORDS_BID_NOTICE_DELAY_MS:
# 叫分阶段成功叫分后的提示展示时间。
LANDLORDS_BID_NOTICE_DELAY_MS=2200

# LANDLORDS_PASS_NOTICE_DELAY_MS:
# 出牌阶段选择“不要”后的提示展示时间。
LANDLORDS_PASS_NOTICE_DELAY_MS=1800

# LANDLORDS_SIMPLE_PLAY_NOTICE_DELAY_MS:
# 普通出牌动作的提示展示时间，例如单张、对子、顺子等常规牌型。
LANDLORDS_SIMPLE_PLAY_NOTICE_DELAY_MS=2200

# LANDLORDS_COMPLEX_PLAY_NOTICE_DELAY_MS:
# 较复杂牌型的提示展示时间，例如连对、飞机等。
LANDLORDS_COMPLEX_PLAY_NOTICE_DELAY_MS=3000

# LANDLORDS_BOMB_NOTICE_DELAY_MS:
# 炸弹出牌提示展示时间。
LANDLORDS_BOMB_NOTICE_DELAY_MS=3400

# LANDLORDS_ROCKET_NOTICE_DELAY_MS:
# 王炸出牌提示展示时间。
LANDLORDS_ROCKET_NOTICE_DELAY_MS=3800

# LANDLORDS_DEFAULT_NOTICE_DELAY_MS:
# 没有被更具体规则覆盖时，默认使用的提示展示时间。
LANDLORDS_DEFAULT_NOTICE_DELAY_MS=2200

# LANDLORDS_MANAGED_DELAY_MIN_MS:
# 托管玩家思考时间的最小值。
LANDLORDS_MANAGED_DELAY_MIN_MS=380

# LANDLORDS_MANAGED_DELAY_MAX_MS:
# 托管玩家思考时间的最大值。
LANDLORDS_MANAGED_DELAY_MAX_MS=680

# LANDLORDS_BOT_BID_DELAY_MIN_MS:
# 机器人叫分时的最小思考时间。
LANDLORDS_BOT_BID_DELAY_MIN_MS=260

# LANDLORDS_BOT_BID_DELAY_MAX_MS:
# 机器人叫分时的最大思考时间。
LANDLORDS_BOT_BID_DELAY_MAX_MS=460

# LANDLORDS_BOT_PLAY_DELAY_MIN_MS:
# 机器人出牌时的最小思考时间。
LANDLORDS_BOT_PLAY_DELAY_MIN_MS=320

# LANDLORDS_BOT_PLAY_DELAY_MAX_MS:
# 机器人出牌时的最大思考时间。
LANDLORDS_BOT_PLAY_DELAY_MAX_MS=520

# LANDLORDS_PRESENTATION_TIMEOUT_MS:
# 动画、提示或表现层步骤的超时时间。
# 如果前端长时间没有确认展示完成，后端会按这个值兜底推进。
LANDLORDS_PRESENTATION_TIMEOUT_MS=15000

# LANDLORDS_FINISH_DELAY_MS:
# 对局结束后，结算前的最终停顿时间。
LANDLORDS_FINISH_DELAY_MS=520


# -----------------------------------------------------------------------------
# 六、Web 发布服务
# -----------------------------------------------------------------------------

# LANDLORDS_WEB_HOST:
# Web 静态资源服务监听 IP。
# 和后端一样，127.0.0.1 只允许本机访问，0.0.0.0 适合对外部署。
LANDLORDS_WEB_HOST=0.0.0.0

# LANDLORDS_WEB_PORT:
# Web 静态资源服务监听端口。
# 浏览器访问的就是这个端口。
LANDLORDS_WEB_PORT=23000

# LANDLORDS_BACKEND_WS_PROXY:
# Web 服务内部把 `/ws` 转发到哪个后端 WebSocket 地址。
# 当前默认值表示 Web 服务和后端部署在同一台机器上，并代理到本机 23002 端口。
# 如果前后端不在同一台机器上，这里要改成真实后端 WebSocket 地址，例如 `ws://你的后端IP:端口/ws`。
LANDLORDS_BACKEND_WS_PROXY=ws://127.0.0.1:23002/ws


# -----------------------------------------------------------------------------
# 七、测试与 smoke 脚本
# -----------------------------------------------------------------------------

# LANDLORDS_TEST_HOST:
# 测试脚本连接后端时使用的主机地址。
# 一般填实际后端所在机器的 IP；本机测试通常保持 127.0.0.1。
# 这组 `LANDLORDS_TEST_*` 只影响测试和 smoke，不影响正式服务运行。
LANDLORDS_TEST_HOST=127.0.0.1

# LANDLORDS_TEST_TCP_PORT:
# 测试脚本连接后端 TCP 服务时使用的端口。
# 通常与 LANDLORDS_PORT 保持一致。
LANDLORDS_TEST_TCP_PORT=23001

# LANDLORDS_TEST_WS_PORT:
# 测试脚本连接后端 WebSocket 服务时使用的端口。
# 通常与 LANDLORDS_WS_PORT 保持一致。
LANDLORDS_TEST_WS_PORT=23002


# -----------------------------------------------------------------------------
# 八、Python ONNX 导出与校验工具
# -----------------------------------------------------------------------------
# 这一段只在“你要自己重新导出 ONNX”或“你要做 Python 侧一致性校验”时才需要关心。
# 如果你只是直接部署仓库当前自带的 ONNX 模型并运行 C++ 后端，可以先不修改这一段。

# LANDLORDS_PYTHON:
# 导出 ONNX 时使用的 Python 解释器。
# 可以写 `python`，也可以写绝对路径，例如 `C:/Python39/python.exe`。
LANDLORDS_PYTHON=python

# LANDLORDS_DOUZERO_ROOT:
# 精简版 DouZero 源码所在目录。
# export_onnx.py 会从这里导入模型和牌局逻辑。
LANDLORDS_DOUZERO_ROOT=third_party/DouZero

# LANDLORDS_DOUZERO_BASELINE_DIR:
# 原始 checkpoint 所在目录。
# 如果你要从自己的 checkpoint 重新导出 ONNX，就把它改成自己的 baseline 目录。
LANDLORDS_DOUZERO_BASELINE_DIR=third_party/baselines/douzero_ADP

# LANDLORDS_DOUZERO_DEVICE:
# Python 侧加载 checkpoint 时使用的设备。
# 常见值：cpu / cuda。
LANDLORDS_DOUZERO_DEVICE=cpu

# LANDLORDS_DOUZERO_NUM_THREADS:
# Python 侧导出和验证时使用的线程数。
LANDLORDS_DOUZERO_NUM_THREADS=4

# LANDLORDS_DOUZERO_PRELOAD:
# 是否在导出前预加载模型。
# 常见值：1 表示开启，0 表示关闭。
LANDLORDS_DOUZERO_PRELOAD=1

# LANDLORDS_DOUZERO_WARMUP:
# 是否在正式导出前先做一次预热推理。
# 常见值：1 表示开启，0 表示关闭。
LANDLORDS_DOUZERO_WARMUP=1

# LANDLORDS_DOUZERO_EXPORT_OUTPUT_DIR:
# 导出的 ONNX 输出目录。
# 留空时，脚本会根据命令行参数或默认逻辑决定输出位置。
LANDLORDS_DOUZERO_EXPORT_OUTPUT_DIR=

# LANDLORDS_DOUZERO_EXPORT_DEVICE:
# 执行 ONNX 导出时使用的设备。
# 常见值：cpu / cuda。
LANDLORDS_DOUZERO_EXPORT_DEVICE=cpu

# LANDLORDS_DOUZERO_LOG_LEVEL:
# Python 导出和校验工具的日志级别。
# 常见值：DEBUG / INFO / WARN / ERROR。
LANDLORDS_DOUZERO_LOG_LEVEL=INFO
