# LandLords unified configuration template.
#
# Copy this file to `landlords.env` and update the values for your machine.
# Backend / test / proxy sections use regular environment variables.
# Frontend values are compile-time constants read through `String.fromEnvironment`,
# so pass those keys with `--dart-define=KEY=value` when running or building Flutter.
#
# Relative paths in the backend sections can stay repo-relative, for example:
#   LANDLORDS_DATA_DIR=runtime
#   LANDLORDS_DOUZERO_ONNX_DIR_EASY=backend/ai_models/onnx/douzero_ADP
#
# Hint and autoplay both use the same DouZero ONNX strategy family:
#   easy   -> DouZero-ADP
#   normal -> DouZero-SL
#   hard   -> DouZero-WP


# -----------------------------------------------------------------------------
# Frontend compile-time config (`flutter run/build --dart-define=...`)
# -----------------------------------------------------------------------------
# Leave empty for same-origin web builds that proxy `/ws`.
LANDLORDS_WS_URL=
LANDLORDS_TCP_HOST=127.0.0.1
LANDLORDS_TCP_PORT=23001
LANDLORDS_MOBILE_WS_URL=ws://10.0.2.2:23002/ws
LANDLORDS_GITHUB_REPO=https://github.com/FILWY2824/LandLords
LANDLORDS_DOWNLOAD_URL=


# -----------------------------------------------------------------------------
# Backend server runtime
# -----------------------------------------------------------------------------
LANDLORDS_HOST=0.0.0.0
LANDLORDS_PORT=23001
LANDLORDS_WS_PORT=23002
LANDLORDS_DATA_DIR=runtime
LANDLORDS_LOG_LEVEL=INFO
LANDLORDS_ROOM_TICK_INTERVAL_MS=100


# -----------------------------------------------------------------------------
# DouZero ONNX runtime
# -----------------------------------------------------------------------------
# `LANDLORDS_DOUZERO_ONNX_DIR` is an optional shared fallback.
# Per-difficulty keys take precedence when they are set.
# Difficulty selectors accept `easy` / `adp`, `normal` / `sl`, `hard` / `wp`.
LANDLORDS_DOUZERO_ONNX_DIR=
LANDLORDS_DOUZERO_ONNX_DIR_EASY=backend/ai_models/onnx/douzero_ADP
LANDLORDS_DOUZERO_ONNX_DIR_NORMAL=backend/ai_models/onnx/sl
LANDLORDS_DOUZERO_ONNX_DIR_HARD=backend/ai_models/onnx/douzero_WP
LANDLORDS_ONNX_NUM_THREADS=1
LANDLORDS_HINT_BOT_DIFFICULTY=hard
LANDLORDS_MANAGED_BOT_DIFFICULTY=hard


# -----------------------------------------------------------------------------
# Room pacing and presentation
# -----------------------------------------------------------------------------
LANDLORDS_BOT_MODEL_RETRY_DELAY_MS=1500
LANDLORDS_MANAGED_NOTICE_DELAY_MS=2300
LANDLORDS_BID_PASS_NOTICE_DELAY_MS=1700
LANDLORDS_BID_NOTICE_DELAY_MS=2200
LANDLORDS_PASS_NOTICE_DELAY_MS=1800
LANDLORDS_SIMPLE_PLAY_NOTICE_DELAY_MS=2200
LANDLORDS_COMPLEX_PLAY_NOTICE_DELAY_MS=3000
LANDLORDS_BOMB_NOTICE_DELAY_MS=3400
LANDLORDS_ROCKET_NOTICE_DELAY_MS=3800
LANDLORDS_DEFAULT_NOTICE_DELAY_MS=2200
LANDLORDS_MANAGED_DELAY_MIN_MS=380
LANDLORDS_MANAGED_DELAY_MAX_MS=680
LANDLORDS_BOT_BID_DELAY_MIN_MS=260
LANDLORDS_BOT_BID_DELAY_MAX_MS=460
LANDLORDS_BOT_PLAY_DELAY_MIN_MS=320
LANDLORDS_BOT_PLAY_DELAY_MAX_MS=520
LANDLORDS_PRESENTATION_TIMEOUT_MS=15000
LANDLORDS_FINISH_DELAY_MS=520


# -----------------------------------------------------------------------------
# Public web bridge (`run_frontend_web_23000.ps1`)
# -----------------------------------------------------------------------------
LANDLORDS_WEB_HOST=0.0.0.0
LANDLORDS_WEB_PORT=23000
LANDLORDS_BACKEND_WS_PROXY=ws://127.0.0.1:23002/ws


# -----------------------------------------------------------------------------
# Integration tests and smoke tools
# -----------------------------------------------------------------------------
LANDLORDS_TEST_HOST=127.0.0.1
LANDLORDS_TEST_TCP_PORT=23001
LANDLORDS_TEST_WS_PORT=23002


# -----------------------------------------------------------------------------
# Python DouZero proxy (`backend/ai_service/douzero_proxy`)
# -----------------------------------------------------------------------------
LANDLORDS_DOUZERO_ROOT=third_party/DouZero
LANDLORDS_DOUZERO_BASELINE_DIR=third_party/baselines/douzero_ADP
LANDLORDS_DOUZERO_DEVICE=cpu
LANDLORDS_DOUZERO_NUM_THREADS=4
LANDLORDS_DOUZERO_PRELOAD=1
LANDLORDS_DOUZERO_WARMUP=1
LANDLORDS_PROXY_LOG_LEVEL=INFO
